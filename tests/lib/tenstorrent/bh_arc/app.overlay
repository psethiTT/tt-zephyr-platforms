/ {
	fwtable: fwtable {
		compatible = "tenstorrent,bh-fwtable";
		status = "okay";
		flash-dev = <&flashcontroller0>;
	};

	pll0: pll0 {
		compatible = "tenstorrent,clock-control-emul";
		status = "okay";
	};

	pll1: pll1 {
		compatible = "tenstorrent,clock-control-emul";
		status = "okay";
	};

	pll4: pll4 {
		compatible = "tenstorrent,clock-control-emul";
		status = "okay";
	};

	dma1: noc_dma {
		status = "okay";
	};

	pvt: pvt {
		compatible = "tenstorrent,bh-pvt-emul";
		num_pd = <16>;
		num_vm = <8>;
		num_ts = <8>;
		pd-raw = <15300>;
		vm-raw = <11795>;
		ts-raw = <1142>;
		status = "okay";
	};

	efuse: efuse {
		compatible = "tenstorrent,bh-efuse-emul";
		status = "okay";
	};

	wdt0: wdt0 {
		compatible = "tenstorrent,bh-watchdog";
		status = "okay";
	};
};

&i2c0 {
	smbus_target0: smbus@0a {
		status = "okay";
		compatible = "zephyr,smbus_target";
		reg = <0x0a>;
	};
};
